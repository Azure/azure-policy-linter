<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <RootNamespace>Microsoft.Azure.Policy.PolicyLinter</RootNamespace>
    <AssemblyName>Microsoft.Azure.Policy.PolicyLinter.Core</AssemblyName>
    <Description>A linter for policy definitions.</Description>
    <Authors>Microsoft</Authors>
    <Company>Microsoft</Company>
    <Copyright>© Microsoft Corporation. All rights reserved.</Copyright>
    <IsPackable>true</IsPackable>
    <PackageId>Microsoft.Azure.Policy.PolicyLinter.Core</PackageId>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Azure.Deployments.Expression" />
    <PackageReference Include="Azure.Deployments.ResourceMetadata" />
    <PackageReference Include="Azure.Deployments.ResourceMetadata.Offline" />
    <PackageReference Include="Microsoft.PowerPlatform.ResourceStack" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="ResourceTypesAndAliases.json" LogicalName="ResourceTypesAndAliases.json" />
  </ItemGroup>

  <PropertyGroup>
    <Nullable>enable</Nullable>
  </PropertyGroup>

</Project>
